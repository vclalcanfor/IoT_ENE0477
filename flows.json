        "func": "const status = { payload: msg.payload.status };\nconst mediaEntrada = { payload: `${msg.payload.mediaEntrada || '-'} L` };\nconst mediaSaida = { payload: `${msg.payload.mediaSaida || '-'} L` };\nconst diferenca = { payload: `${msg.payload.diferenca || '-'} L` };\n\nreturn [status, mediaEntrada, mediaSaida, diferenca];",
