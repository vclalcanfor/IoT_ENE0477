        "func": "const acumulado = context.get('acumulado_saida') || {};\nconst sensor = msg.topic;\nconst volumeIncremental = parseFloat(msg.payload);\n\n// Acumula volume\nconst volumeAtual = (acumulado[sensor] || 0) + volumeIncremental;\nacumulado[sensor] = volumeAtual;\ncontext.set('acumulado_saida', acumulado);\n\n// Mensagem para o Supabase\nconst msgSupabase = {\n    payload: {\n        sensor: sensor,\n        vazao_lmin: volumeIncremental,\n        // volume_acumulado_l: parseFloat(volumeAtual.toFixed(4))\n    }\n};\n\nreturn msgSupabase;",
