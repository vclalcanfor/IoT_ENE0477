    {
        "id": "258a581e49d04094",
        "type": "function",
        "z": "dd089ebc01fe5ab7",
        "name": "function 5",
        "func": "const volumeIncremental = parseFloat(msg.payload);\nconst acumulado = (flow.get('acumulado_saida') || 0) + volumeIncremental;\nflow.set('acumulado_saida', acumulado);\n\nconst agora = Date.now();\n\nnode.send([\n    {\n        topic: \"Volume Instantâneo (L)\",\n        payload: volumeIncremental,\n        timestamp: agora\n    },\n    {\n        topic: \"Volume Acumulado (L)\",\n        payload: parseFloat(acumulado.toFixed(4)),\n        timestamp: agora\n    }\n]);\n\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
