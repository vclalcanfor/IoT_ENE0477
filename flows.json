    {
        "id": "bb11b444bb11a451",
        "type": "function",
        "z": "dd089ebc01fe5ab7",
        "name": "function 9",
        "func": "if (!msg.topic) {\n    msg.payload = {\n        status: \"Coletando dados...\",\n        mediaEntrada: null,\n        mediaSaida: null,\n        diferenca: null\n    };\n    return msg;\n}\n\nconst JANELA = 10;\nconst TOLERANCIA_L = 0.5;\nconst AMOSTRAS_MIN_ALERTA = 5;\n\nconst sensor = msg.topic.includes('entrada') ? 'entrada' : 'saida';\nconst valor = parseFloat(msg.payload);\n\n// Recupera ou inicializa o histórico de cada sensor\nlet historicoEntrada = flow.get('historicoVazamento_entrada') || [];\nlet historicoSaida = flow.get('historicoVazamento_saida') || [];\n\nif (sensor === 'entrada') {\n    historicoEntrada.push(valor);\n    if (historicoEntrada.length > JANELA) historicoEntrada.shift();\n    flow.set('historicoVazamento_entrada', historicoEntrada);\n} else {\n    historicoSaida.push(valor);\n    if (historicoSaida.length > JANELA) historicoSaida.shift();\n    flow.set('historicoVazamento_saida', historicoSaida);\n}\n\n// Só avalia quando os dois sensores já têm dados suficientes\nif (historicoEntrada.length < JANELA || historicoSaida.length < JANELA) {\n    msg.payload = {\n        status: \"Coletando dados...\",\n        mediaEntrada: null,\n        mediaSaida: null,\n        diferenca: null\n    };\n    return msg;\n}\n\nconst mediaEntrada = historicoEntrada.reduce((a, b) => a + b, 0) / historicoEntrada.length;\nconst mediaSaida = historicoSaida.reduce((a, b) => a + b, 0) / historicoSaida.length;\nconst diferenca = mediaEntrada - mediaSaida;\n\n// Contador de amostras consecutivas com diferença acima da tolerância\nlet contadorAlerta = flow.get('contadorAlertaVazamento') || 0;\n\nif (diferenca > TOLERANCIA_L) {\n    contadorAlerta++;\n} else {\n    contadorAlerta = 0;\n}\nflow.set('contadorAlertaVazamento', contadorAlerta);\n\nconst vazamentoDetectado = contadorAlerta >= AMOSTRAS_MIN_ALERTA;\n\nmsg.payload = {\n    status: vazamentoDetectado ? \"⚠️ Possível vazamento detectado\" : \"✅ Normal\",\n    mediaEntrada: mediaEntrada.toFixed(3),\n    mediaSaida: mediaSaida.toFixed(3),\n    diferenca: diferenca.toFixed(3),\n    vazamentoDetectado\n};\n\nreturn msg;",
