        "z": "dd089ebc01fe5ab7",
        "name": "Criação da API URL",
        "func": "const ultimoTimestamp = flow.get('ultimoTimestamp_saida') || null;\nconst timestampEncoded = encodeURIComponent(ultimoTimestamp);\n\nif (ultimoTimestamp) {\n    // Busca só os registros novos\n    msg.url = `https://tdwoglxvqtmcqcuikzyb.supabase.co/rest/v1/leituras?sensor=eq.iot%2Fagua%2Fsaida&created_at=gt.${timestampEncoded}&order=created_at.asc`;\n} else {\n    // Primeira carga — busca tudo\n    msg.url = `https://tdwoglxvqtmcqcuikzyb.supabase.co/rest/v1/leituras?sensor=eq.iot%2Fagua%2Fsaida&order=created_at.asc`;\n}\n\nreturn msg;",
