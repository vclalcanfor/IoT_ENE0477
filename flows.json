    {
        "id": "82fe2207d50a080d",
        "type": "function",
        "z": "dd089ebc01fe5ab7",
        "name": "Atualização do gráfico",
        "func": "if (msg.statusCode !== 200) {\n    node.error(\"Erro na requisição: \" + msg.statusCode);\n    return null;\n}\n\nconst dados = Array.isArray(msg.payload) \n    ? msg.payload \n    : JSON.parse(msg.payload);\n\nif (dados.length === 0) return null;\n\n// Limpa os dois gráficos antes de carregar histórico\nnode.send([\n    { topic: \"Volume Instantâneo (L)\", payload: [], action: \"replace\" },\n    { topic: \"Volume Acumulado (L)\", payload: [], action: \"replace\" }\n]);\n\n// Acumula para o gráfico de acumulado\nlet acumulado = 0;\n\ndados.forEach(d => {\n    acumulado += parseFloat(d.vazao_lmin);\n\n    node.send([\n        {\n            topic: \"Volume Instantâneo (L)\",\n            payload: parseFloat(d.vazao_lmin),\n            timestamp: new Date(d.created_at).getTime()\n        },\n        {\n            topic: \"Volume Acumulado (L)\",\n            payload: parseFloat(acumulado.toFixed(4)),\n            timestamp: new Date(d.created_at).getTime()\n        }\n    ]);\n});\n\n// Salva o acumulado final para o MQTT continuar de onde parou\nflow.set('acumulado_saida', acumulado);\n\nreturn null;",
