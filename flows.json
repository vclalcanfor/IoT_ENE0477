        "func": "const msg1 = { payload: `${msg.payload.consumoAtualM3} m³` };\nconst msg2 = { payload: `R$ ${msg.payload.faturaAtual}` };\nconst msg3 = { payload: `${msg.payload.consumoProjetadoM3} m³` };\nconst msg4 = { payload: `R$ ${msg.payload.faturaProjetada}` };\n\nreturn [msg1, msg2, msg3, msg4];",
