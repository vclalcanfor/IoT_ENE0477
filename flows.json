    {
        "id": "2e8e6b5adb10c504",
        "type": "function",
        "z": "dd089ebc01fe5ab7",
        "name": "function 6",
        "func": "const volumeLitros = flow.get('acumulado_entrada') || 0;\nconst consumoM3 = volumeLitros / 1000;\n\nconst TAXA_FIXA = 11.62;\nconst FAIXAS = [\n    { limite: 7,  preco: 4.30  },\n    { limite: 13, preco: 5.15  },\n    { limite: 20, preco: 10.21 },\n    { limite: 30, preco: 14.81 },\n    { limite: 45, preco: 22.22 },\n    { limite: Infinity, preco: 28.88 }\n];\n\nfunction calcularValorAgua(m3) {\n    let valorVariavel = 0;\n    let restante = m3;\n    let limiteAnterior = 0;\n    for (const faixa of FAIXAS) {\n        if (restante <= 0) break;\n        const volumeFaixa = Math.min(restante, faixa.limite - limiteAnterior);\n        valorVariavel += volumeFaixa * faixa.preco;\n        restante -= volumeFaixa;\n        limiteAnterior = faixa.limite;\n    }\n    return TAXA_FIXA + valorVariavel;\n}\n\n// Usa o timestamp da leitura (histórico) ou agora (tempo real)\nconst timestampLeitura = msg.timestamp || Date.now();\n\nlet historico = flow.get('historicoRegressao_entrada') || [];\nhistorico.push({ t: timestampLeitura, v: consumoM3 });\n\nconst JANELA_MAX = 50;\nif (historico.length > JANELA_MAX) {\n    historico = historico.slice(-JANELA_MAX);\n}\nflow.set('historicoRegressao_entrada', historico);\n\nfunction regressaoLinear(pontos) {\n    const n = pontos.length;\n    if (n < 2) return { a: 0, b: pontos[0]?.v || 0 };\n\n    const t0 = pontos[0].t;\n    const xs = pontos.map(p => (p.t - t0));\n    const ys = pontos.map(p => p.v);\n\n    const somaX = xs.reduce((s, x) => s + x, 0);\n    const somaY = ys.reduce((s, y) => s + y, 0);\n    const somaXY = xs.reduce((s, x, i) => s + x * ys[i], 0);\n    const somaXX = xs.reduce((s, x) => s + x * x, 0);\n\n    const denom = (n * somaXX - somaX * somaX);\n    const a = denom !== 0 ? (n * somaXY - somaX * somaY) / denom : 0;\n    const b = (somaY - a * somaX) / n;\n\n    return { a, b, t0 };\n}\n\nconst { a } = regressaoLinear(historico);\nconst consumoPorMs = Math.max(a, 0);\nconst MS_NO_MES = 30 * 24 * 60 * 60 * 1000;\nconst consumoProjetadoM3 = consumoM3 + (consumoPorMs * MS_NO_MES * (historico.length / JANELA_MAX));\n\nlet inicioColeta = flow.get('inicioColeta_entrada');\nif (!inicioColeta) {\n    inicioColeta = timestampLeitura;\n    flow.set('inicioColeta_entrada', inicioColeta);\n}\nconst horasDecorridas = Math.max((timestampLeitura - inicioColeta) / (1000 * 60 * 60), 0.01);\nconst consumoProjetadoFallback = (consumoM3 / horasDecorridas) * 720;\n\nconst projecaoFinal = historico.length >= 5 ? consumoProjetadoM3 : consumoProjetadoFallback;\n\nconst valorAgua = calcularValorAgua(consumoM3);\nconst totalAtual = valorAgua * 2;\n\nconst valorAguaProjetado = calcularValorAgua(Math.max(projecaoFinal, 0));\nconst totalProjetado = valorAguaProjetado * 2;\n\nmsg.payload = {\n    consumoAtualM3: consumoM3.toFixed(3),\n    consumoAtualL: volumeLitros.toFixed(1),\n    faturaAtual: totalAtual.toFixed(2),\n    consumoProjetadoM3: Math.max(projecaoFinal, 0).toFixed(3),\n    faturaProjetada: totalProjetado.toFixed(2)\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1720,
        "y": 1140,
        "wires": [
